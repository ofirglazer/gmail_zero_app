# gmail_zero_app — environment configuration template
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must never be committed.

# ── Runtime environment ───────────────────────────────────────────────────────
# Options: production | demo
# Use 'demo' to run with synthetic mock data (no Gmail credentials required).
GMAIL_ZERO_ENV=demo

# ── Flask ─────────────────────────────────────────────────────────────────────
# SECURITY: Generate a strong random key for production.
# python -c "import secrets; print(secrets.token_hex(32))"
GMAIL_ZERO_SECRET_KEY=replace-this-with-a-strong-random-secret

# Host is hardcoded to 127.0.0.1 (local only) but port is configurable.
GMAIL_ZERO_PORT=5000

# Set to true only during development — never in production.
GMAIL_ZERO_DEBUG=false

# ── File paths ────────────────────────────────────────────────────────────────
# Paths are relative to the project root unless absolute.
GMAIL_ZERO_DB_PATH=data/gmail_zero_app.db
GMAIL_ZERO_CREDENTIALS_PATH=data/credentials/credentials.json
GMAIL_ZERO_TOKEN_PATH=data/credentials/token.json
GMAIL_ZERO_LABELS_CONFIG_PATH=config/labels.toml

# ── Sync behaviour ────────────────────────────────────────────────────────────
# Number of messages fetched per batch during full sync.
GMAIL_ZERO_SYNC_BATCH_SIZE=100

# Milliseconds to pause between API batch calls (rate limiting).
GMAIL_ZERO_SYNC_RATE_LIMIT_DELAY_MS=50

# ── Size thresholds ───────────────────────────────────────────────────────────
# Messages above these byte sizes are flagged in the Size Reduction workflow.
# Defaults: 5 MB and 15 MB.
GMAIL_ZERO_LARGE_MESSAGE_THRESHOLD_BYTES=5242880
GMAIL_ZERO_VERY_LARGE_MESSAGE_THRESHOLD_BYTES=15728640

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Days of history shown on progress graphs.
GMAIL_ZERO_GRAPH_HISTORY_DAYS=30

# Threads older than these thresholds (days) are flagged as unresolved.
GMAIL_ZERO_OLD_THREAD_THRESHOLD_DAYS=30
GMAIL_ZERO_VERY_OLD_THREAD_THRESHOLD_DAYS=90
